# Server
PORT=3001
NODE_ENV=development

# Database
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password
DB_NAME=whatsapp_platform

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_this
JWT_EXPIRES_IN=7d

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173

# WhatsApp sessions folder
SESSIONS_DIR=./whatsapp/sessions

# Uploads folder
UPLOADS_DIR=./uploads

# Worker interval (ms)
WORKER_INTERVAL=5000

# Max queue retries
QUEUE_MAX_ATTEMPTS=3
